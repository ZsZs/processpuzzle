{
  "name": "processpuzzle-testbed",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/processpuzzle-testbed/src",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/processpuzzle-testbed",
        "index": "apps/processpuzzle-testbed/src/index.html",
        "browser": "apps/processpuzzle-testbed/src/main.ts",
        "polyfills": [],
        "tsConfig": "apps/processpuzzle-testbed/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/processpuzzle-testbed/public"
          },
          {
            "glob": "**/*",
            "input": "apps/processpuzzle-testbed/src/assets",
            "output": "assets"
          },
          {
            "glob": "**/*",
            "input": "libs/js-shared/auth/feature/assets/auth",
            "output": "assets/auth"
          },
          {
            "glob": "**/*",
            "input": "libs/js-shared/auth/feature/assets/i18n/auth",
            "output": "assets/i18n/auth"
          },
          {
            "glob": "**/*",
            "input": "libs/js-shared/base-entity/src/assets/i18n/base-entity",
            "output": "assets/i18n/base-entity"
          },
          {
            "glob": "**/*",
            "input": "libs/js-shared/design/src/assets/i18n/design",
            "output": "assets/i18n/design"
          },
          {
            "glob": "**/*",
            "input": "libs/js-shared/widgets/src/assets/i18n/widgets",
            "output": "assets/i18n/widgets"
          },
          "apps/processpuzzle-testbed/src/environments",
          "apps/processpuzzle-testbed/src/run-time-conf"
        ],
        "styles": [
          "apps/processpuzzle-testbed/src/custom-theme.scss",
          "apps/processpuzzle-testbed/src/styles.scss",
          "node_modules/prismjs/themes/prism-okaidia.css",
          "node_modules/prismjs/plugins/line-numbers/prism-line-numbers.css",
          "node_modules/prismjs/plugins/line-highlight/prism-line-highlight.css",
          "node_modules/prismjs/plugins/command-line/prism-command-line.css"
        ],
        "scripts": [
          "node_modules/clipboard/dist/clipboard.min.js",
          "node_modules/mermaid/dist/mermaid.min.js",
          "node_modules/prismjs/prism.js",
          "node_modules/prismjs/components/prism-csharp.min.js",
          "node_modules/prismjs/components/prism-css.min.js",
          "node_modules/prismjs/components/prism-typescript.min.js",
          "node_modules/prismjs/components/prism-javascript.min.js",
          "node_modules/prismjs/plugins/line-numbers/prism-line-numbers.js",
          "node_modules/prismjs/plugins/line-highlight/prism-line-highlight.js",
          "node_modules/prismjs/plugins/command-line/prism-command-line.js"
        ],
        "allowedCommonJsDependencies": ["prismjs", "build-url-ts", "reflect-metadata"]
      },
      "configurations": {
        "production": {
          "baseHref": "/",
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "6mb",
              "maximumError": "8mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "12kb",
              "maximumError": "20kb"
            }
          ],
          "outputHashing": "all",
          "sourceMap": {
            "scripts": true,
            "styles": true,
            "hidden": false,
            "vendor": false
          }
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "processpuzzle-testbed:build:production"
        },
        "development": {
          "buildTarget": "processpuzzle-testbed:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/processpuzzle-testbed/proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "processpuzzle-testbed:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/js-shared/base-entity/src/**/*.ts", "libs/js-shared/base-entity/src/**/*.spec.ts"]
      },
      "configurations": {
        "ci": {
          "format": "json",
          "outputFile": "{projectRoot}/reports/eslint/eslint.json"
        },
        "dev": {
          "format": "html",
          "outputFile": "{workspaceRoot}/reports/eslint/{projectRoot}/eslint.html"
        }
      }
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "outputs": ["{projectRoot}/reports/coverage"],
      "dependsOn": ["^build"],
      "options": {
        "runner": "vitest",
        "runnerConfig": "apps/processpuzzle-testbed/vitest.config.ts",
        "tsConfig": "apps/processpuzzle-testbed/tsconfig.spec.json",
        "coverage": true
      },
      "configurations": {
        "ci": {
          "coverage": true,
          "coverageReporters": ["lcov", "json-summary"]
        }
      }
    },
    "serve-static": {
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "processpuzzle-testbed:build",
        "port": 4200,
        "staticFilePath": "dist/apps/processpuzzle-testbed/browser",
        "spa": true
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{workspaceRoot}/dist/apps/processpuzzle-testbed"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "processpuzzle-backend:build"],
      "options": {
        "command": "docker compose -f tools/docker/docker-compose-ci.yaml build"
      }
    }
  }
}
