{
    "name": "@processpuzzle/functions",
    "version": "0.0.1",
    "description": "Cloud Functions for Firebase",
    "scripts": {
        "lint": "eslint --ext .js,.ts .",
        "sync-db": "node -e \"const fs=require('fs');const db=require('../../mock-backend/db.js')();const json=JSON.stringify(db,null,2);fs.writeFileSync('db.json',json);fs.mkdirSync('lib',{recursive:true});fs.writeFileSync('lib/db.json',json)\"",
        "build": "npm run sync-db && tsc",
        "build:watch": "npm run sync-db && tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "22"
    },
    "main": "lib/index.js",
    "dependencies": {
        "@types/json-server": "^0.14.8",
        "firebase-admin": "^13.0.0",
        "firebase-functions": "^7.2.5",
        "json-server": "^0.17.4"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "eslint-plugin-prettier": "^5.5.6",
        "firebase-functions-test": "^3.5.0",
        "typescript": "~6.0.3"
    },
    "private": false
}
