{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "origin/develop",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.js",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s"
    ],
    "sharedGlobals": []
  },
  "nxCloudId": "675f0ad038484f3c2d2ee0d3",
  "targetDefaults": {
    "@angular/build:application": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "options": {}
    },
    "@nx/eslint:lint": {
      "cache": true,
      "inputs": ["default", "{workspaceRoot}/.eslintrc.json", "{workspaceRoot}/.eslintignore", "{workspaceRoot}/eslint.config.js"]
    },
    "@angular/build:unit-test": {
      "cache": true,
      "inputs": ["default", "^production"],
      "outputs": ["{projectRoot}/reports/coverage"],
      "options": {
        "passWithNoTests": true,
        "codeCoverage": true,
        "coverageReporters": ["html", "lcov", "text"],
        "coverageThresholds": {
          "statements": 80,
          "branches": 80,
          "functions": 80,
          "lines": 80
        },
        "reportsDirectory": "{projectRoot}/coverage/{projectRoot}"
      },
      "configurations": {
        "ci": {
          "ci": true,
          "coverage": true,
          "coverageReporters": ["lcov", "json-summary"],
          "coverageDirectory": "{projectRoot}/reports/coverage"
        }
      }
    },
    "e2e-ci--**/*": {
      "dependsOn": ["^build"]
    },
    "nx-release-publish": {
      "dependsOn": [],
      "options": {
        "packageRoot": "dist/{projectName}"
      }
    },
    "@nx/esbuild:esbuild": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/angular:package": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  },
  "plugins": [
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/js/typescript",
      "include": ["libs/test-util/*"],
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build",
          "configName": "tsconfig.lib.json"
        }
      }
    }
  ],
  "release": {
    "projects": ["auth", "base-entity", "processpuzzle-testbed", "test-util", "util", "widgets"],
    "projectsRelationship": "independent",
    "version": {
      "preVersionCommand": "npm run build-all-ci",
      "conventionalCommits": true
    },
    "conventionalCommits": {
      "types": {
        "docs": {
          "semverBump": "none",
          "changelog": {
            "title": "Documentation Changes"
          }
        },
        "chore": {
          "changelog": false
        }
      }
    },
    "versionPlans": {
      "ignorePatternsForPlanCheck": ["**/*.spec.ts"]
    },
    "releaseTagPattern": "release/{projectName}/{version}",
    "git": {
      "commitMessage": "chore(release): {projectName}-{version}"
    },
    "changelog": {
      "file": false,
      "createRelease": "github",
      "projectChangelogs": true
    }
  },
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "playwright",
      "linter": "eslint",
      "style": "css",
      "unitTestRunner": "none"
    },
    "@nx/angular:component": {
      "style": "css"
    },
    "@nx/angular:library": {
      "linter": "eslint",
      "unitTestRunner": "none"
    }
  }
}
