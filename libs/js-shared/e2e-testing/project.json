{
  "name": "e2e-testing",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/js-shared/e2e-testing/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  },
  "tags": ["scope:shared", "type:e2e-util"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/js-shared/e2e-testing",
        "main": "libs/js-shared/e2e-testing/src/public-api.ts",
        "tsConfig": "libs/js-shared/e2e-testing/tsconfig.lib.json",
        "assets": ["libs/js-shared/e2e-testing/*.md"]
      }
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.js",
        {
          "externalDependencies": ["eslint"]
        }
      ],
      "configurations": {
        "ci": {
          "format": "json",
          "output-file": "reports/eslint/eslint.json"
        },
        "dev": {
          "format": "html",
          "output-file": "reports/eslint/eslint.html"
        }
      },
      "outputs": ["{projectRoot}/reports/eslint/eslint.json", "{projectRoot}/reports/eslint/eslint.html", "{options.outputFile}"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  }
}
