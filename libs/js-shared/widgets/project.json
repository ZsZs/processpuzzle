{
  "name": "widgets",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "root": "libs/js-shared/widgets",
  "sourceRoot": "libs/js-shared/widgets/src",
  "prefix": "pp",
  "tags": ["scope:shared", "type:widgets"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "dependsOn": ["^build"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/js-shared/widgets/ng-package.json",
        "tsConfig": "libs/js-shared/widgets/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/js-shared/widgets/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/js-shared/widgets/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/reports/coverage"],
      "options": {
        "runner": "vitest",
        "runnerConfig": "libs/js-shared/widgets/vitest.config.ts",
        "tsConfig": "libs/js-shared/widgets/tsconfig.spec.json",
        "setupFiles": ["libs/js-shared/widgets/test-setup.ts"],
        "coverage": true
      },
      "configurations": {
        "ci": {
          "coverage": true,
          "coverageReporters": ["lcov", "json-summary"]
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/js-shared/widgets/**/*.ts", "libs/js-shared/widgets/**/*.spec.ts"]
      },
      "configurations": {
        "ci": {
          "format": "json",
          "outputFile": "{projectRoot}/reports/eslint/eslint.json"
        },
        "dev": {
          "format": "html",
          "outputFile": "{workspaceRoot}/reports/eslint/{projectRoot}/eslint.html"
        }
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{workspaceRoot}/dist/libs/js-shared/widgets"
      }
    }
  }
}
