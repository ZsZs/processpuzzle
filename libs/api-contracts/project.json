{
  "name": "api-contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/api-contracts/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -f {projectRoot}/pom.xml install"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -f {projectRoot}/pom.xml clean validate"
      },
      "configurations": {
        "ci": {},
        "dev": {}
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -f {projectRoot}/pom.xml test"
      },
      "configurations": {
        "ci": {}
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}"
      }
    }
  },
  "tags": []
}
