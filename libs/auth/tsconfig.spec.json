{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": ["vitest/globals", "node", "@testing-library/jest-dom"],
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "files": ["test-setup.ts"],
  "include": ["vitest.config.ts", "domain/**/*.test.ts", "feature/**/*.test.ts", "domain/**/*.d.ts", "feature/**/*.d.ts", "feature/**/*.spec.ts", "domain/**/*.spec.ts"]
}
