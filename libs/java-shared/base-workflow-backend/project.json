{
  "name": "base-workflow-backend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["backend", "java", "springboot", "library"],
  "sourceRoot": "libs/java-shared/base-workflow-backend/src",
  "implicitDependencies": ["api-contracts", "processpuzzle-core", "base-state-backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "mvn -pl libs/java-shared/base-workflow-backend clean install"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -f {projectRoot}/pom.xml clean validate"
      },
      "configurations": {
        "ci": {},
        "dev": {}
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -pl libs/java-shared/base-workflow-backend -am test"
      },
      "configurations": {
        "ci": {}
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release-java-lib.mjs prepare --project {projectName}"
      }
    },
    "release-finalize": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node tools/scripts/release-java-lib.mjs finalize --project {projectName}"
      }
    }
  }
}
