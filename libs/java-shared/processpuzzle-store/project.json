{
  "name": "processpuzzle-store",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "tags": ["backend", "java", "springboot", "library"],
  "sourceRoot": "libs/java-shared/processpuzzle-store/src",
  "implicitDependencies": ["api-contracts", "processpuzzle-core"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "mvn -pl libs/java-shared/processpuzzle-store clean install"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -f {projectRoot}/pom.xml clean validate"
      },
      "configurations": {
        "ci": {},
        "dev": {}
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn -pl libs/java-shared/processpuzzle-store -am test"
      },
      "configurations": {
        "ci": {}
      }
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "{projectRoot}"
      }
    }
  }
}
