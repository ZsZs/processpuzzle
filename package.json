{
  "name": "@processpuzzle/main",
  "version": "0.2.1",
  "license": "MIT",
  "scripts": {
    "config-env-api-contracts": "echo 'Not applicable'",
    "config-env-auth": "echo 'Not applicable'",
    "config-env-base-entity": "echo 'Not applicable'",
    "config-env-e2e-testing": "echo 'Not applicable'",
    "config-env-object-store": "echo 'Not applicable'",
    "config-env-testbed": "ts-node apps/processpuzzle-testbed/src/assets/setEnv.ts",
    "config-env-test-util": "echo 'Not applicable'",
    "config-env-ui": "echo 'Not applicable'",
    "config-env-util": "echo 'Not applicable'",
    "config-env-widgets": "echo 'Not applicable'",
    "copy-config": "cp -R apps/processpuzzle-testbed/src/run-time-conf/config.local.json cp -R apps/processpuzzle-testbed/src/run-time-conf/config.custom.json ",
    "copy-package-json": "cp -R apps/processpuzzle-testbed/package.json dist/apps/processpuzzle-testbed",
    "i18n:extract": "transloco-keys-manager extract",
    "i18n:find": "transloco-keys-manager find",
    "playwright-codeget": "npx playwright codegen http://localhost:4200",
    "run-mock-backend": "npx json-server --watch tools/mock-backend/db.json --port 3000",
    "run-mock-outh2": "npx oauth2-mock-server",
    "run-http-server": "http-server dist/apps/processpuzzle-testbed/browser --proxy http://localhost:9090",
    "run-firebase-emulator": "firebase emulators:start --import apps/processpuzzle-testbed/data",
    "stop-firebase-emulator": "lsof -t -i:5001 -i:5002 -i:8080 -i:9000 -i:9099 -i:9199 -i:9090 | xargs kill -9",
    "serve-processpuzzle-testbed": "npm run config-env-testbed -- --environment=dev && nx run processpuzzle-testbed:serve",
    "serve-processpuzzle-ui": "nx run processpuzzle-ui:serve --configuration=de-DE",
    "build-all": "nx run-many -t build --configuration=production --no-cloud",
    "build-api-contracts": "nx run api-contracts:build --configuration=production --no-cloud",
    "build-auth": "nx run auth:build --configuration=production --no-cloud",
    "build-base-entity": "nx run base-entity:build --configuration=production --no-cloud",
    "build-e2e-testing": "nx run e2e-testing:build --no-cloud",
    "build-testbed": "nx run processpuzzle-testbed:build --configuration=production --no-cloud",
    "build-test-util": "nx run test-util:build --configuration=production --no-cloud",
    "build-util": "nx run util:build --configuration=production --no-cloud",
    "build-widgets": "nx run widgets:build --configuration=production --no-cloud",
    "lint-all": "nx run-many -t lint --no-cloud",
    "lint-api-contracts": "nx run api-contracts:lint --configuration=ci --no-cloud",
    "lint-auth": "nx run auth:lint --configuration=ci --no-cloud",
    "lint-base-entity": "nx run base-entity:lint --configuration=ci --no-cloud",
    "lint-e2e-testing": "nx run e2e-testing:lint --configuration=ci --no-cloud",
    "lint-object-store": "nx run object-store:lint --configuration=ci --no-cloud",
    "lint-testbed": "nx run processpuzzle-testbed:lint --configuration=ci --no-cloud",
    "lint-test-util": "nx run test-util:lint --configuration=ci --no-cloud",
    "lint-util": "nx run util:lint --configuration=ci --no-cloud",
    "lint-widgets": "nx run widgets:lint --configuration=ci --no-cloud",
    "publish-all": "nx release --skip-publish --no-cloud",
    "publish-all-ci": "nx release publish --dry-run --no-cloud",
    "publish-testbed": "npm run copy-package-json && nx run processpuzzle-testbed:nx-release-publish --first-release --exclude=base-entity, test-util, util --access public --no-cloud",
    "release-all": "npm run copy-package-json && nx release publish --skip-publish --no-cloud --dry-run",
    "release-check": "nx release plan:check --no-cloud",
    "e2e-test-processpuzzle-testbed": "nx e2e processpuzzle-testbed-e2e --no-cloud",
    "release": "ts-node tools/scripts/release.ts",
    "release:dry": "DRY_RUN=true ts-node tools/scripts/release.ts",
    "test-all": "nx run-many -t test --exclude=processpuzzle-testbed --configuration=ci --no-cloud",
    "test-api-contracts": "nx run api-contracts:test --configuration=ci --no-cloud",
    "test-auth": "nx run auth:test --configuration=ci --coverage --no-cloud --skip-nx-cache",
    "test-base-entity": "nx run base-entity:test --configuration=ci --coverage --no-cloud",
    "test-e2e-testing": "echo 'No unit tests for e2e-testing'",
    "test-object-store": "nx run object-store:test --configuration=ci --no-cloud",
    "test-testbed": "nx run processpuzzle-testbed:test --configuration=ci --coverage --no-cloud",
    "test-test-util": "nx run test-util:test --configuration=ci --coverage --no-cloud",
    "test-util": "nx run util:test --configuration=ci --coverage --no-cloud",
    "test-widgets": "nx run widgets:test --configuration=ci --coverage --no-cloud",
    "test-widgets-ui": "nx run widgets:test --ui"
  },
