{
  "root": true,
  "ignorePatterns": ["**/*"],
  "plugins": ["@nx", "html"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "@nx/enforce-module-boundaries": [
          "error",
          {
            "enforceBuildableLibDependency": true,
            "allow": [
              "@angular/**",
              "@basis-gui/**",
              "@ngrx",
              "build-url-ts",
              "eslint",
              "rxjs",
              "uuid",
              "@processpuzzle/auth/domain",
              "@processpuzzle/auth/feature",
              "@analogjs/*",
              "@analogjs/vitest-angular",
              "@analogjs/vite-plugin-angular"
            ],
            "depConstraints": [
              {
                "sourceTag": "scope:shared",
                "onlyDependOnLibsWithTags": ["scope:shared", "scope:base-entity"]
              },
              {
                "sourceTag": "scope:base-entity",
                "onlyDependOnLibsWithTags": ["scope:shared"]
              },
              {
                "sourceTag": "type:app",
                "onlyDependOnLibsWithTags": ["scope:*", "type:auth", "type:feature", "type:util", "type:test-util", "type:widget"]
              },
              {
                "sourceTag": "type:domain",
                "onlyDependOnLibsWithTags": ["type:domain", "type:util", "type:test-util"]
              },
              {
                "sourceTag": "type:feature",
                "onlyDependOnLibsWithTags": ["type:domain", "type:util", "type:test-util", "type:test-util"]
              },
              {
                "sourceTag": "type:usecase",
                "onlyDependOnLibsWithTags": ["type:domain", "type:util"]
              },
              {
                "sourceTag": "type:util",
                "onlyDependOnLibsWithTags": ["type:util", "type:test-util"]
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@nx/typescript"],
      "rules": {
        "@typescript-eslint/no-explicit-any": "off"
      }
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["plugin:@nx/javascript"],
      "rules": {}
    },
    {
      "files": ["*.spec.ts", "*.spec.tsx", "*.spec.js", "*.spec.jsx"],
      "globals": {
        "vi": "readonly",
        "describe": "readonly",
        "it": "readonly",
        "expect": "readonly",
        "beforeEach": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "afterAll": "readonly",
        "test": "readonly"
      },
      "rules": {}
    },
    {
      "files": ["**/test-setup.ts", "**/vitest.config.ts", "**/vitest.config.mts"],
      "rules": {
        "@nx/enforce-module-boundaries": "off"
      }
    }
  ]
}
