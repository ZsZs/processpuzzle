{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "declarationMap": true,
    "inlineSources": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "importHelpers": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "module": "es2022",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@processpuzzle/auth": ["libs/auth/public-api.ts"],
      "@processpuzzle/auth/domain": ["libs/auth/domain/public-api.ts"],
      "@processpuzzle/auth/feature": ["libs/auth/feature/public-api.ts"],
      "@processpuzzle/base-entity": ["libs/base-entity/src/public-api.ts"],
      "@processpuzzle/test-util": ["libs/test-util/src/public-api.ts"],
      "@processpuzzle/util": ["libs/util/src/public-api.ts"],
      "@processpuzzle/widgets": ["libs/widgets/src/public-api.ts"],
      "@processpuzzle/widgets/mat-cards-grid": ["libs/widgets/mat-cards-grid/public-api.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
