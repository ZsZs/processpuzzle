{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "moduleResolution": "bundler",
    "types": ["node"],
    "importHelpers": true,
    "experimentalDecorators": true,
    "target": "es2022",
    "module": "es2022",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@processpuzzle/auth": ["./libs/js-shared/auth/public-api.ts"],
      "@processpuzzle/auth/domain": ["./libs/js-shared/auth/domain/public-api.ts"],
      "@processpuzzle/auth/feature": ["./libs/js-shared/auth/feature/public-api.ts"],
      "@processpuzzle/base-desktop": ["./libs/js-shared/base-desktop-frontend/src/public-api.ts"],
      "@processpuzzle/base-entity": ["./libs/js-shared/base-entity-frontend/src/public-api.ts"],
      "@processpuzzle/base-process": ["./libs/js-shared/base-process-frontend/src/public-api.ts"],
      "@processpuzzle/base-rule": ["./libs/js-shared/base-rule-frontend/src/public-api.ts"],
      "@processpuzzle/base-state": ["./libs/js-shared/base-state-frontend/src/public-api.ts"],
      "@processpuzzle/design": ["./libs/js-shared/design/src/public-api.ts"],
      "@processpuzzle/test-util": ["./libs/js-shared/test-util/src/public-api.ts"],
      "@processpuzzle/util": ["./libs/js-shared/util/src/public-api.ts"],
      "@processpuzzle/widgets": ["./libs/js-shared/widgets/src/public-api.ts"],
      "@processpuzzle/e2e-testing": ["./libs/js-shared/e2e-testing/src/public-api.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
